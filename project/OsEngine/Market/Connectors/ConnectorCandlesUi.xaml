<Window x:Class="OsEngine.Market.Connectors.ConnectorCandlesUi"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Data flow connection" Height="680" Width="450.43" Style="{StaticResource WindowStyleNoResize}" ResizeMode="NoResize" WindowStartupLocation="CenterScreen" Icon="/Images/OsLogo.ico">
    <Grid>
        <Rectangle Margin="5,188,5,0" />
        <Rectangle Margin="5,52,5,0" Height="131" VerticalAlignment="Top" />
        <Rectangle Margin="5,5,5,0" Height="41" VerticalAlignment="Top" />

        <Label Name="Label1" Content="Server" HorizontalAlignment="Left" Margin="41,14,0,0" VerticalAlignment="Top"/>
        <ComboBox Name="ComboBoxTypeServer" Margin="206,14,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Width="184"/>

        <Label Name="Label2" Content="Order execution" HorizontalAlignment="Left" Margin="10,51,0,0" VerticalAlignment="Top" FontWeight="Bold" FontSize="18"/>

        <Label Name="Label3" Content="Portfolio for operations" HorizontalAlignment="Left"  Margin="41,75,0,0" VerticalAlignment="Top"/>
        <ComboBox Name="ComboBoxPortfolio" Margin="206,75,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Width="184"/>

        <CheckBox Name="CheckBoxIsEmulator" Content="Execute trades in the emulator" HorizontalAlignment="Left" Margin="120,103,0,0" VerticalAlignment="Top"/>

        <Label Name="LabelCommissionType" Content="Commission type" HorizontalAlignment="Left"  Margin="41,126,0,0" VerticalAlignment="Top"/>
        <ComboBox Name="ComboBoxCommissionType" Margin="206,126,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Width="184"/>

        <Label Name="LabelCommissionValue" Content="Commission value" HorizontalAlignment="Left" Margin="41,154,0,0" VerticalAlignment="Top" />
        <TextBox Name ="TextBoxCommissionValue" Margin="206,154,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Width="184"  />

        <Label Name="Label5" Content="Security" HorizontalAlignment="Left" Margin="10,184,0,0" VerticalAlignment="Top" FontWeight="Bold" FontSize="18"/>

        <Label Name="Label6" Content="Classes displayed" HorizontalAlignment="Left" Margin="29,213,0,0" VerticalAlignment="Top"/>
        <ComboBox Name="ComboBoxClass" Margin="0,213,0,0" VerticalAlignment="Top" HorizontalAlignment="Center" Width="163"/>
        <Button Name="ButtonLeftInSearchResults" Content="&lt;" HorizontalAlignment="Left" Margin="310,193,0,0" VerticalAlignment="Top" Width="23" Height="20"/>
        <Label Name="LabelCurrentResultShow" Content="1" HorizontalAlignment="Left" Margin="346,193,0,0" VerticalAlignment="Top" Height="20"/>
        <Label Name="LabelCommasResultShow" Content="...." HorizontalAlignment="Left" Margin="361,193,0,0" VerticalAlignment="Top" Height="20"/>
        <Label Name="LabelCountResultsShow" Content="8" HorizontalAlignment="Left" Margin="380,193,0,0" VerticalAlignment="Top" Height="20"/>
        <Button Name="ButtonRightInSearchResults" Content=">" HorizontalAlignment="Left" Margin="407,193,0,0" VerticalAlignment="Top" Width="23" Height="20"/>
        <TextBox Name="TextBoxSearchSecurity" HorizontalAlignment="Left" Margin="310,213,0,0" TextWrapping="Wrap" Text="search..." VerticalAlignment="Top" Width="120"/>

        <Label Name="Label18" Content="Expiration" HorizontalAlignment="Left" Margin="29,236,0,0" VerticalAlignment="Top"/>
        <ComboBox Name="ComboBoxExpiration" Margin="0,236,0,0" VerticalAlignment="Top" HorizontalAlignment="Center" Width="163"/>

        <Label Name="Label19" Content="Strike" HorizontalAlignment="Left" Margin="30,259,0,0" VerticalAlignment="Top"/>
        <ComboBox Name="ComboBoxStrike" Margin="0,259,0,0" VerticalAlignment="Top" HorizontalAlignment="Center" Width="163"/>

        <!-- размер SecurityTable меняется в коде -->
        <WindowsFormsHost Name="SecurityTable" HorizontalAlignment="Left" Height="184" Margin="12,236,0,0" VerticalAlignment="Top" Width="418"/>

        <Grid Name="GridCandleType" Margin="10,440,18,35">

            <Label Name="Label8" Content="From what we collect candles" HorizontalAlignment="Left" Margin="9,15,0,0" VerticalAlignment="Top"/>
            <ComboBox Name ="ComboBoxCandleMarketDataType" Margin="214,15,19,0" VerticalAlignment="Top" />
            <Label Name="Label9" Content="Candle type" HorizontalAlignment="Left" Margin="9,63,0,0" VerticalAlignment="Top" />
            <ComboBox Name ="ComboBoxCandleCreateMethodType" Margin="214,63,19,0" VerticalAlignment="Top"  />
            <CheckBox Name="CheckBoxSaveTradeArrayInCandle" Content="Save trades array in Candle" HorizontalAlignment="Left" Margin="88,40,0,0" VerticalAlignment="Top"/>
            <Label Name="LabelCandleType" Content="Candle type" HorizontalAlignment="Left" Margin="0,-10,0,0" VerticalAlignment="Top" FontWeight="Bold" FontSize="18"/>
            <WindowsFormsHost Name ="HostCandleSeriesParameters" Margin="50,92,50,4"/>
            <Button Name="ButtonMarketDepthBuildMaxSpread" Content="i" Margin="399,16,0,0" VerticalAlignment="Top" Height="21" HorizontalAlignment="Left" Width="17" Click="ButtonMarketDepthBuildMaxSpread_Click"/>
        </Grid>

        <Button Name="ButtonAccept" Content="Accept" HorizontalAlignment="Right" Margin="0,0,18.8,9.8" VerticalAlignment="Bottom" Width="130" Click="ButtonAccept_Click"/>
        <Button Name="ButtonPostConnectorCandles" HorizontalAlignment="Left" Margin="10,0,0,10" VerticalAlignment="Bottom" Height="36" Width="35" Click="ButtonPostConnectorCandles_Click">
            <Grid>
                <Image Name="PostGreenConnectorCandles" Source="/Images/InstructionPosts/GreenPost.png"  Width="31" Height="25" />
                <Image Name="PostWhiteConnectorCandles"  Source="/Images/InstructionPosts/WhitePost.png" Width="31" Height="25" Opacity="0" />
            </Grid>
        </Button>
    </Grid>
</Window>