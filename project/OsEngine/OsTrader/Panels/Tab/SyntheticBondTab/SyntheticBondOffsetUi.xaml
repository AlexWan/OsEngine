<Window x:Class="OsEngine.OsTrader.Panels.Tab.SyntheticBondTab.SyntheticBondOffsetUi"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OsEngine.OsTrader.Panels.Tab.SyntheticBondTab"
        mc:Ignorable="d"
        Title="Price offsets and modifications" Height="330" Width="650" MinHeight="330" MinWidth="650" MaxHeight="280" MaxWidth="650" Style="{StaticResource WindowStyleCanResize}" WindowStartupLocation="CenterScreen" Icon="/Images/OsLogo.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="55*"/>
            <RowDefinition Height="70*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50*"/>
                <ColumnDefinition Width="50*"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Column="1" Content="Нормирование" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5, 5, 5, 5" Width="140" Height="25" FontSize="16" />
            <ComboBox Grid.Column="1" Name="RationingUsingAnotherToolBaseComboBox" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="150, 5 , 5, 5" Height="25" Width="165" FontSize="16"/>

            <Label Grid.Column="1" Content="Инструмент нормирования:" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5, 40, 5, 5" Height="25" Width="310" HorizontalContentAlignment="Center" FontSize="16"/>
            <Button Grid.Column="1" Content="None" Name="RationingToolBaseButton" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5,70, 5, 5" Height="25" Width="310" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="16"/>

            <Label Grid.Column="1" Content="Тип нормирования" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5, 100, 5, 5" Width="160" Height="25" FontSize="16"/>
            <ComboBox Grid.Column="1" Name="RationingModeBaseComboBox" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="170, 100, 5, 5" Height="25" Width="145" FontSize="16"/>

            <Label Grid.Column="1" Content="Смещение времени (час)" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5, 130, 5, 5" Width="160" Height="25" FontSize="16"/>
            <TextBox Grid.Column="1" Name="TimeOffsetBaseRationingTextBox" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="170, 130, 5, 5" Height="25" Width="145" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="16"/>


            <Label Grid.Column="0" Content="Нормирование" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5,5, 5, 5" Width="140" Height="25" FontSize="16" />
            <ComboBox Grid.Column="0" Name="RationingUsingAnotherToolFuturesComboBox" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="150, 5, 5, 5" Height="25" Width="165" FontSize="16" />

            <Label Grid.Column="0" Content="Инструмент нормирования:" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5, 40, 5, 5" Height="25" Width="310" HorizontalContentAlignment="Center" FontSize="16"/>
            <Button Grid.Column="0" Content="None" Name="RationingToolFuturesButton" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5,70, 5, 5" Height="25" Width="310" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="16" />

            <Label Grid.Column="0" Content="Тип нормирования" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5, 100, 5, 5" Width="160" Height="25" FontSize="16"/>
            <ComboBox Grid.Column="0" Name="RationingModeFuturesComboBox" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="170, 100, 5, 5" Height="25" Width="145" FontSize="16"/>

            <Label Grid.Column="0" Content="Смещение времени (час)" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5, 130, 5, 5" Width="160" Height="25" FontSize="16"/>
            <TextBox Grid.Column="0" Name="TimeOffsetFuturesRationingTextBox" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="170, 130, 5, 5" Height="25" Width="145" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="16"/>
        </Grid>

        <Label Grid.Row="0" Content="Основная формула" Name="LabelMainFormula" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"  HorizontalAlignment="Center" VerticalAlignment="Top" Margin="1,5,1,1" FontSize="16"/>

        <Label Grid.Row="0" Content="База" HorizontalAlignment="Right"  VerticalAlignment="Top" Margin="5, 5, 100, 5" Height="25" Width="70" FontSize="16"/>
        <Label Grid.Row="0" Content="None" Name="BaseSynteticBondOffsetsLabel" HorizontalAlignment="Right"  VerticalAlignment="Top" Margin="5, 40, 5, 5"  Height="25" Width="240" HorizontalContentAlignment ="Center" VerticalContentAlignment="Center" FontSize="16"/>

        <Label Grid.Row="0" Content="Фьючерс" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="110, 5, 5, 5"  Height="25" Width="80" FontSize="16"/>
        <Label Grid.Row="0" Content="None" Name="FuturesSynteticBondOffsetsLabel"  Height="25" Width="230" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5, 40, 5, 5" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="16"/>

        <Label Grid.Row="0" Content="Смещение времени (час)" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5, 70, 5, 5" Width="160" Height="25" FontSize="16"/>
        <TextBox Grid.Row="0" Name="TimeOffsetBaseTextBox" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="500, 70, 5, 5" Height="25" Width="145" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="16"/>

        <Label Grid.Row="0" Content="Смещение времени (час)" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="335, 70, 5, 5" Width="160" Height="25" FontSize="16"/>
        <TextBox Grid.Row="0" Name="TimeOffsetFuturesTextBox" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="170, 70, 5, 5"  Height="25" Width="145" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="16"/>

        <Label Grid.Row="0" Content="Мультипликатор" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5, 100, 5, 5" Width="140" Height="25" FontSize="16"/>
        <TextBox Grid.Row="0" Name="MultiplicatorBaseTextBox" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="500, 100, 5, 5" Height="25" Width="145"  FontSize="16" HorizontalContentAlignment="Center"  VerticalContentAlignment="Center"/>

        <Label Grid.Column="1" Content="Мультипликатор" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="335, 100, 5, 5" Width="140" Height="25" FontSize="16"/>
        <TextBox Grid.Column="1" Name="MultiplicatorFuturesTextBox" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="150, 100, 5, 5"  Height="25" Width="165"  FontSize="16" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>

        <ComboBox Grid.Row="0" Name="ComboBoxSimbolFurmula" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="1,40,1,1" Width="150" FontSize="16"/>

    </Grid>
</Window>
