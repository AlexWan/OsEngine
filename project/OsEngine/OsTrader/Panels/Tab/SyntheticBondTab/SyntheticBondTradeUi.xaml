<Window x:Class="OsEngine.OsTrader.Panels.Tab.SynteticBondTab.SynteticBondTradeUi"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OsEngine.OsTrader.Panels.Tab.SynteticBondTab"
        mc:Ignorable="d"
        Title="SynteticBondTradeUi" Height="795" Width="1050" MinHeight="795" MinWidth="1050"
        Style="{StaticResource WindowStyleCanResize}" WindowStartupLocation="CenterScreen" Icon="/Images/OsLogo.ico">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="200"/>
            <RowDefinition Height="370"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== Верхняя панель: Статус / Коинтеграция / Управление ===== -->
        <Grid Grid.Row="0" Margin="5,5,5,5" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="310"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="270"/>
            </Grid.ColumnDefinitions>

            <!-- Левая группа: режим и спред -->
            <GroupBox Grid.Column="0" Margin="0,0,5,0" Padding="5,2,5,5" BorderBrush="#FF555555">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="27"/>
                        <RowDefinition Height="27"/>
                        <RowDefinition Height="27"/>
                        <RowDefinition Height="27"/>
                        <RowDefinition Height="27"/>
                        <RowDefinition Height="27"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Name="CurrentModeLabel" Content="Current mode:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" Name="TradeModeComboBox" Height="23" VerticalAlignment="Center" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>

                    <Label Grid.Row="1" Grid.Column="0" Name="CurrentSpreadLabel" Content="Current spread:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Name="CurrentSpreadTextBox" Height="23" VerticalAlignment="Center" IsReadOnly="True" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                    <Label Grid.Row="2" Grid.Column="0" Name="MaxSpreadLabel" Content="Max spread:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Name="MaxSpreadTextBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                    <Label Grid.Row="3" Grid.Column="0" Name="MinSpreadLabel" Content="Min spread:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Name="MinSpreadTextBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                </Grid>
            </GroupBox>

            <!-- Средняя группа -->
            <GroupBox Grid.Column="1" Margin="0,0,5,0" Padding="5,2,5,5" BorderBrush="#FF555555">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="27"/>
                        <RowDefinition Height="27"/>
                        <RowDefinition Height="27"/>
                        <RowDefinition Height="27"/>
                        <RowDefinition Height="27"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Name="LabelCointegrationDeviation" Content="Cointegration deviation" VerticalAlignment="Center" Padding="2,0,0,0"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Name="TextBoxCointegrationDeviation" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                    <Label Grid.Row="1" Grid.Column="0" Name="LabelCointegrationLookBack" Content="Cointegration lookback" VerticalAlignment="Center" Padding="2,0,0,0"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Name="TextBoxCointegrationLookBack" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                    <Label Grid.Row="2" Grid.Column="0" Name="LabelContangoLookBack" Content="Contango lookback" VerticalAlignment="Center" Padding="2,0,0,0"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Name="TextBoxContangoLookBack" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                    <Label Grid.Row="3" Grid.Column="0" Name="LabelScenario" Content="Script:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                    <ComboBox Grid.Row="3" Grid.Column="1" Name="ScenarioComboBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                    <TextBox Grid.Row="4" Grid.Column="0" Name="ScenarioTextBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Left" Margin="0,0,3,0"/>
                    <Button Grid.Row="4" Grid.Column="1" Name="CreateScriptButton" Content="Create script" Height="23" VerticalAlignment="Center" Click="CreateScriptButton_Click"/>

                    <Grid Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Bottom">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Name="StartButton" Content="Start"
                                Margin="2,3,2,3" Height="25" VerticalAlignment="Center" Click="StartButton_Click"/>
                        <Button Grid.Column="1" Name="PauseButton" Content="Pause"
                                Margin="2,3,2,3" Height="25" VerticalAlignment="Center" Click="PauseButton_Click"/>
                        <Button Grid.Column="2" Name="DeleteScenarioButton" Content="Delete"
                                Margin="2,3,2,3" Height="25" VerticalAlignment="Center" Click="DeleteScenarioButton_Click"/>
                    </Grid>
                </Grid>
            </GroupBox>

            <!-- Правая группа: управление роботом -->
            <GroupBox Grid.Column="2" Padding="5,2,5,5" BorderBrush="#FF555555">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="22"/>
                        <RowDefinition Height="27"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Name="NonTradePeriodButton" Content="Non trade period"
                            Height="25" VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="0,2,0,2"/>

                    <Label Grid.Row="2" Name="ServerTimeLabel" Content="Current server time"
                           VerticalAlignment="Center" HorizontalAlignment="Center" Padding="2,0,0,0"/>

                    <TextBox Grid.Row="3" Name="ServerTimeTextBox" Height="23"
                             VerticalAlignment="Center" IsReadOnly="True"
                             VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- ===== TabControl ===== -->
        <TabControl Grid.Row="1" Margin="5,0,5,0">

            <TabItem Header="Entering a position" Name="EnterPositionTabItem">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Security 1 -->
                    <GroupBox Grid.Column="0" Margin="5,5,3,5" Padding="5,2,5,5" BorderBrush="#FF555555">
                        <GroupBox.Header>
                            <Label Name="EnterBaseNameLabel" Content="Security 1" FontWeight="SemiBold" Padding="0" VerticalAlignment="Center"/>
                        </GroupBox.Header>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="160"/>
                            </Grid.ColumnDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Name="EnterLabelAssetPortfolioSec1" Content="Asset in portfolio" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Name="EnterTextBoxAssetPortfolioSec1" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="1" Grid.Column="0" Name="EnterVolumeTypeSec1Label" Content="Volume type:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <ComboBox Grid.Row="1" Grid.Column="1" Name="EnterVolumeTypeSec1ComboBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="2" Grid.Column="0" Name="EnterTotalVolumeSec1Label" Content="Total volume:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Name="EnterTotalVolumeSec1TextBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="3" Grid.Column="0" Name="EnterOneOrderSec1" Content="One order:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Name="EnterOneOrderSec1TextBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="4" Grid.Column="0" Name="EnterOrderTypeSec1Label" Content="Order type:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <ComboBox Grid.Row="4" Grid.Column="1" Name="EnterOrderTypeSec1ComboBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="5" Grid.Column="0" Name="EnterPositionSec1Label" Content="Order position:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <ComboBox Grid.Row="5" Grid.Column="1" Name="EnterOrderPositionSec1ComboBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="6" Grid.Column="0" Name="EnterSlippageSec1Label" Content="Slippage:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <TextBox Grid.Row="6" Grid.Column="1" Name="EnterSlippageSec1TextBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="7" Grid.Column="0" Name="EnterLifetimeOrderSec1Label" Content="Lifetime of the order:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <TextBox Grid.Row="7" Grid.Column="1" Name="EnterLifetimeOrderSec1TextBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="8" Grid.Column="0" Name="EnterOrderFrequencySec1Label" Content="Order frequency (sec):" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <TextBox Grid.Row="8" Grid.Column="1" Name="EnterOrderFrequencySec1TextBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="9" Grid.Column="0" Name="EnterCurrentVolumeSec1Label" Content="Current volume:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <TextBox Grid.Row="9" Grid.Column="1" Name="EnterCurrentVolumeSec1TextBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" IsReadOnly="True"/>
                        </Grid>
                    </GroupBox>

                    <!-- Security 2 -->
                    <GroupBox Grid.Column="1" Margin="3,5,5,5" Padding="5,2,5,5" BorderBrush="#FF555555">
                        <GroupBox.Header>
                            <Label Name="EnterFuturesNameLabel" Content="Security 2" FontWeight="SemiBold" Padding="0" VerticalAlignment="Center"/>
                        </GroupBox.Header>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="160"/>
                            </Grid.ColumnDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Name="EnterLabelAssetPortfolioSec2" Content="Asset in portfolio" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Name="EnterTextBoxAssetPortfolioSec2" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="1" Grid.Column="0" Name="EnterVolumeTypeSec2Label" Content="Volume type:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <ComboBox Grid.Row="1" Grid.Column="1" Name="EnterVolumeTypeSec2ComboBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="2" Grid.Column="0" Name="EnterTotalVolumeSec2Label" Content="Total volume:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Name="EnterTotalVolumeSec2TextBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="3" Grid.Column="0" Name="EnterOneOrderSec2" Content="One order:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Name="EnterOneOrderSec2TextBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="4" Grid.Column="0" Name="EnterOrderTypeSec2Label" Content="Order type:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <ComboBox Grid.Row="4" Grid.Column="1" Name="EnterOrderTypeSec2ComboBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="5" Grid.Column="0" Name="EnterPositionSec2Label" Content="Order position:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <ComboBox Grid.Row="5" Grid.Column="1" Name="EnterOrderPositionSec2ComboBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="6" Grid.Column="0" Name="EnterSlippageSec2Label" Content="Slippage:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <TextBox Grid.Row="6" Grid.Column="1" Name="EnterSlippageSec2TextBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="7" Grid.Column="0" Name="EnterLifetimeOrderSec2Label" Content="Lifetime of the order:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <TextBox Grid.Row="7" Grid.Column="1" Name="EnterLifetimeOrderSec2TextBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="8" Grid.Column="0" Name="EnterOrderFrequencySec2Label" Content="Order frequency (sec):" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <TextBox Grid.Row="8" Grid.Column="1" Name="EnterOrderFrequencySec2TextBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="9" Grid.Column="0" Name="EnterCurrentVolumeSec2Label" Content="Current volume:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <TextBox Grid.Row="9" Grid.Column="1" Name="EnterCurrentVolumeSec2TextBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" IsReadOnly="True"/>
                        </Grid>
                    </GroupBox>

                </Grid>
            </TabItem>

            <TabItem Header="Exit from the position" Name="ExitFromPositionTabItem">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Security 1 -->
                    <GroupBox Grid.Column="0" Margin="5,5,3,5" Padding="5,2,5,5" BorderBrush="#FF555555">
                        <GroupBox.Header>
                            <Label Name="ExitBaseNameLabel" Content="Security 1" FontWeight="SemiBold" Padding="0" VerticalAlignment="Center"/>
                        </GroupBox.Header>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="160"/>
                            </Grid.ColumnDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Name="ExitLabelAssetPortfolioSec1" Content="Asset in portfolio" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Name="ExitTextBoxAssetPortfolioSec1" Height="23" VerticalAlignment="Center" IsReadOnly="True" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="1" Grid.Column="0" Name="ExitVolumeTypeSec1Label" Content="Volume type:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <ComboBox Grid.Row="1" Grid.Column="1" Name="ExitVolumeTypeSec1ComboBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="2" Grid.Column="0" Name="ExitTotalVolumeSec1Label" Content="Total volume:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Name="ExitTotalVolumeSec1TextBox" Height="23" VerticalAlignment="Center" IsReadOnly="True" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="3" Grid.Column="0" Name="ExitOneOrderSec1" Content="One order:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Name="ExitOneOrderSec1TextBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="4" Grid.Column="0" Name="ExitOrderTypeSec1Label" Content="Order type:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <ComboBox Grid.Row="4" Grid.Column="1" Name="ExitOrderTypeSec1ComboBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="5" Grid.Column="0" Name="ExitPositionSec1Label" Content="Order position:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <ComboBox Grid.Row="5" Grid.Column="1" Name="ExitOrderPositionSec1ComboBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="6" Grid.Column="0" Name="ExitSlippageSec1Label" Content="Slippage:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <TextBox Grid.Row="6" Grid.Column="1" Name="ExitSlippageSec1TextBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="7" Grid.Column="0" Name="ExitLifetimeOrderSec1Label" Content="Lifetime of the order:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <TextBox Grid.Row="7" Grid.Column="1" Name="ExitLifetimeOrderSec1TextBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="8" Grid.Column="0" Name="ExitOrderFrequencySec1Label" Content="Order frequency (sec):" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <TextBox Grid.Row="8" Grid.Column="1" Name="ExitOrderFrequencySec1TextBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="9" Grid.Column="0" Name="ExitCurrentVolumeSec1Label" Content="Current volume:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <TextBox Grid.Row="9" Grid.Column="1" Name="ExitCurrentVolumeSec1TextBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" IsReadOnly="True"/>
                        </Grid>
                    </GroupBox>

                    <!-- Security 2 -->
                    <GroupBox Grid.Column="1" Margin="3,5,5,5" Padding="5,2,5,5" BorderBrush="#FF555555">
                        <GroupBox.Header>
                            <Label Name="ExitFuturesNameLabel" Content="Security 2" FontWeight="SemiBold" Padding="0" VerticalAlignment="Center"/>
                        </GroupBox.Header>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="160"/>
                            </Grid.ColumnDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Name="ExitLabelAssetPortfolioSec2" Content="Asset in portfolio" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Name="ExitTextBoxAssetPortfolioSec2" Height="23" VerticalAlignment="Center" IsReadOnly="True" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="1" Grid.Column="0" Name="ExitVolumeTypeSec2Label" Content="Volume type:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <ComboBox Grid.Row="1" Grid.Column="1" Name="ExitVolumeTypeSec2ComboBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="2" Grid.Column="0" Name="ExitTotalVolumeSec2Label" Content="Total volume:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Name="ExitTotalVolumeSec2TextBox" Height="23" VerticalAlignment="Center" IsReadOnly="True" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="3" Grid.Column="0" Name="ExitOneOrderSec2" Content="One order:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Name="ExitOneOrderSec2TextBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="4" Grid.Column="0" Name="ExitOrderTypeSec2Label" Content="Order type:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <ComboBox Grid.Row="4" Grid.Column="1" Name="ExitOrderTypeSec2ComboBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="5" Grid.Column="0" Name="ExitPositionSec2Label" Content="Order position:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <ComboBox Grid.Row="5" Grid.Column="1" Name="ExitOrderPositionSec2ComboBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="6" Grid.Column="0" Name="ExitSlippageSec2Label" Content="Slippage:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <TextBox Grid.Row="6" Grid.Column="1" Name="ExitSlippageSec2TextBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="7" Grid.Column="0" Name="ExitLifetimeOrderSec2Label" Content="Lifetime of the order:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <TextBox Grid.Row="7" Grid.Column="1" Name="ExitLifetimeOrderSec2TextBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="8" Grid.Column="0" Name="ExitOrderFrequencySec2Label" Content="Order frequency (sec):" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <TextBox Grid.Row="8" Grid.Column="1" Name="ExitOrderFrequencySec2TextBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                            <Label Grid.Row="9" Grid.Column="0" Name="ExitCurrentVolumeSec2Label" Content="Current volume:" VerticalAlignment="Center" Padding="2,0,0,0"/>
                            <TextBox Grid.Row="9" Grid.Column="1" Name="ExitCurrentVolumeSec2TextBox" Height="23" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" IsReadOnly="True"/>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="Open position" Name="OpenPositionTabItem">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <GroupBox Grid.Column="0" Margin="5,5,3,5" Padding="5,2,5,5" BorderBrush="#FF555555">
                        <GroupBox.Header>
                            <Label Name="OpenStepsBaseNameLabel" Content="Security 1" FontWeight="SemiBold" Padding="0" VerticalAlignment="Center"/>
                        </GroupBox.Header>
                        <DataGrid Name="OpenStepsBaseDataGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  FontSize="12"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  GridLinesVisibility="None"
                                  HeadersVisibility="Column"
                                  BorderBrush="#FF151A1E"
                                  Style="{StaticResource DataGridStyle}">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#FF151A1E"/>
                                    <Setter Property="Foreground" Value="#FF9A9C9E"/>
                                    <Setter Property="BorderBrush" Value="#FF555555"/>
                                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                    <Setter Property="MinHeight" Value="30"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="5"/>
                                    <Setter Property="FontWeight" Value="Normal"/>
                                    <Setter Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" TextWrapping="Wrap" TextAlignment="Center"/>
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2a323a"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                        </DataGrid>
                    </GroupBox>

                    <GroupBox Grid.Column="1" Margin="3,5,5,5" Padding="5,2,5,5" BorderBrush="#FF555555">
