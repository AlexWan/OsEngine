<Window x:Class="OsEngine.OsTrader.Panels.Tab.Internal.PositionAddingUi2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OsEngine.OsTrader.Panels.Tab.Internal"
        mc:Ignorable="d"
         Title="Position adding" Height="570" MinHeight="570" Width="520" MinWidth="520"  Icon="/Images/OsLogo.ico" Style="{StaticResource WindowStyleCanResize}" WindowStartupLocation="CenterScreen" >
    <Grid>
        <Grid HorizontalAlignment="Left" Width="187" Margin="0,0,0,268">
            <Label Name="LabelServerType" Content="Server:" HorizontalAlignment="Left" Margin="1,30,0,0" VerticalAlignment="Top"/>
            <Label Name="LabelServerTypeValue" Content="BinanceFutures" HorizontalAlignment="Left" Margin="72,30,0,0" VerticalAlignment="Top" Width="115"/>
            <Label Name="LabelSecurity" Content="Security:" HorizontalAlignment="Left" Margin="1,58,0,0" VerticalAlignment="Top"/>
            <Label Name="LabelSecurityValue" Content="BNBUSDT" HorizontalAlignment="Left" Margin="72,58,0,0" VerticalAlignment="Top" Width="115"/>
            <Label Name="LabelTabName" Content="Bot tab:" HorizontalAlignment="Left" Margin="1,86,0,0" VerticalAlignment="Top"/>
            <Label Name="LabelTabNameValue" Content="TabName" HorizontalAlignment="Left" Margin="72,86,0,0" VerticalAlignment="Top" Width="115"/>
            <Label Name="LabelPosNumber" Content="Pos num:" HorizontalAlignment="Left" Margin="1,112,0,0" VerticalAlignment="Top"/>
            <Label Name="LabelPosNumberValue" Content="Number" HorizontalAlignment="Left" Margin="72,112,0,0" VerticalAlignment="Top" Width="115"/>
            <Label Name="LabelPosState" Content="Pos state:" HorizontalAlignment="Left" Margin="1,140,0,0" VerticalAlignment="Top"/>
            <Label Name="LabelPosStateValue" Content="Open" HorizontalAlignment="Left" Margin="72,140,0,0" VerticalAlignment="Top" Width="115"/>
            <Label Name="LabelOpenSide" Content="Side:" HorizontalAlignment="Left" Margin="1,168,0,0" VerticalAlignment="Top"/>
            <Label Name="LabelOpenSideValue" Content="Buy" HorizontalAlignment="Left" Margin="72,168,0,0" VerticalAlignment="Top" Width="115"/>
            <Label Name="LabelOpenVolume" Content="Volume:" HorizontalAlignment="Left" Margin="1,196,0,0" VerticalAlignment="Top"/>
            <Label Name="LabelOpenVolumeValue" Content="1.3" HorizontalAlignment="Left" Margin="72,196,0,0" VerticalAlignment="Top" Width="115"/>
            <Button Name="ButtonPostPositionAdding" HorizontalAlignment="Left" Margin="10,0,0,10" VerticalAlignment="Bottom" Height="36" Width="34" Click="ButtonPostPositionAdding_Click">
                <Grid>
                    <Image Name="PostGreenPositionAdding" Source="/Images/InstructionPosts/GreenPost.png"  Width="31" Height="25" />
                    <Image Name="PostWhitePositionAdding"  Source="/Images/InstructionPosts/WhitePost.png" Width="31" Height="25" Opacity="0" />
                </Grid>
            </Button>
        </Grid>
        <TabControl Name="TabControlTypePosition" Margin="0,0,0,2" Height="265" VerticalAlignment="Bottom">
            <TabItem Header="Limit" Name ="TabItemLimit" Width="100">
                <Grid>
                    <TextBox Name="TextBoxLimitPrice" HorizontalAlignment="Left" Margin="205,70,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="199"/>
                    <Label Name="LabelLimitPrice" Content="Price" HorizontalAlignment="Left" Margin="74,70,0,0" VerticalAlignment="Top"/>
                    <TextBox Name="TextBoxLimitVolume" HorizontalAlignment="Left" Margin="205,95,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="199"/>
                    <Label Name="LabelLimitVolume" Content="Volume" HorizontalAlignment="Left" Margin="74,95,0,0" VerticalAlignment="Top"/>
                    <Button Name="ButtonAddAtLimit" Height="40" Content="Buy at limit" Margin="155,0,155,10" VerticalAlignment="Bottom" Click="ButtonAddAtLimit_Click"/>
                </Grid>
            </TabItem>

            <TabItem Header="Market" Name ="TabItemMarket" Width="104" HorizontalAlignment="Left" Margin="2,0,0,0">
                <Grid>
                    <TextBox Name="TextBoxMarketVolume" HorizontalAlignment="Left" Margin="205,83,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="199"/>
                    <Label Name="LabelMarketVolume" Content="Volume" HorizontalAlignment="Left" Margin="74,83,0,0" VerticalAlignment="Top"/>
                    <Button Name="ButtonAddAtMarket" Height="40" Content="Buy at market" Margin="155,0,155,10" VerticalAlignment="Bottom" Click="ButtonAddAtMarket_Click"/>
                </Grid>
            </TabItem>

            <TabItem Header="Stop-Limit" Name ="TabItemStop" Width="100" HorizontalAlignment="Right">
                <Grid>
                    <ComboBox Name="ComboBoxStopLimitType" HorizontalAlignment="Left" Margin="205,20,0,0" VerticalAlignment="Top" Width="199"/>
                    <Label Name="LabelStopActivationType" Content="Activation Type" HorizontalAlignment="Left" Margin="74,20,0,0" VerticalAlignment="Top"/>

                    <ComboBox Name="ComboBoxStopLifetimeType" HorizontalAlignment="Left" Margin="205,45,0,0" VerticalAlignment="Top" Width="199"/>
                    <Label Name="LabelStopLifeTimeType" Content="Lifetime Type" HorizontalAlignment="Left" Margin="74,45,0,0" VerticalAlignment="Top"/>

                    <TextBox Name="TextBoxStopLifeTime" HorizontalAlignment="Left" Margin="205,70,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="199"/>
                    <Label Name="LabelStopLifeTime" Content="Lifetime candles" HorizontalAlignment="Left" Margin="74,70,0,0" VerticalAlignment="Top"/>

                    <TextBox Name="TextBoxStopActivationPrice" HorizontalAlignment="Left" Margin="205,95,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="199"/>
                    <Label Name="LabelStopActivationPrice" Content="Activation Price" HorizontalAlignment="Left" Margin="74,95,0,0" VerticalAlignment="Top"/>

                    <TextBox Name="TextBoxStopPrice" HorizontalAlignment="Left" Margin="205,120,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="199"/>
                    <Label Name="LabelStopPrice" Content="Price" HorizontalAlignment="Left" Margin="74,120,0,0" VerticalAlignment="Top"/>

                    <TextBox Name="TextBoxStopVolume" HorizontalAlignment="Left" Margin="205,145,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="199"/>
                    <Label Name="LabelStopVolume" Content="Volume" HorizontalAlignment="Left" Margin="74,145,0,0" VerticalAlignment="Top"/>

                    <Button Name="ButtonAddAtStop" Height="40" Content="Buy at stop" Margin="155,0,155,10" VerticalAlignment="Bottom" Click="ButtonAddAtStop_Click"/>
                </Grid>
            </TabItem>

            <TabItem Header="Fake" Name ="TabItemFake" Width="100">
                <Grid>
                    <TextBox Name="TextBoxFakePrice" HorizontalAlignment="Left" Margin="205,95,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="199"/>
                    <Label Name="LabelFakePrice" Content="Price" HorizontalAlignment="Left" Margin="74,95,0,0" VerticalAlignment="Top"/>
                    <DatePicker Name="DatePickerFakeOpenDate" HorizontalAlignment="Left" Margin="205,45,0,0" VerticalAlignment="Top" Width="139"/>
                    <Label Name="LabelFakeOpenDate" Content="Open Date" HorizontalAlignment="Left" Margin="74,45,0,0" VerticalAlignment="Top"/>
                    <TextBox Name="TextBoxFakeOpenTime" HorizontalAlignment="Left" Margin="205,70,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="139"/>
                    <Label Name="LabelFakeOpenTime" Content="Open Time" HorizontalAlignment="Left" Margin="74,70,0,0" VerticalAlignment="Top"/>
                    <Button Name="ButtonFakeTimeOpenNow" Content="Now" HorizontalAlignment="Left" Margin="349,45,0,0" VerticalAlignment="Top" Height="48" Width="55" Click="ButtonFakeTimeOpenNow_Click"/>
                    <TextBox Name="TextBoxFakeVolume" HorizontalAlignment="Left" Margin="205,120,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="199"/>
                    <Label Name="LabelFakeVolume" Content="Volume" HorizontalAlignment="Left" Margin="74,120,0,0" VerticalAlignment="Top"/>
                    <Button Name="ButtonAddAtFake" Height="40" Content="Buy at fake" Margin="155,0,155,10" VerticalAlignment="Bottom" Click="ButtonAddAtFake_Click"/>
                </Grid>
            </TabItem>

        </TabControl>
        <WindowsFormsHost Name="WinFormsHostMarketDepth" Margin="188,0,4,267"/>
    </Grid>
</Window>