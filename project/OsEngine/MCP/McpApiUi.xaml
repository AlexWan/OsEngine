<Window x:Class="OsEngine.MCP.McpApiUi"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OsEngine.MCP"
        mc:Ignorable="d"
        Title="MCP API" Height="600" Width="850" MinWidth="850" MinHeight="400"
        Style="{StaticResource WindowStyleCanResize}" WindowStartupLocation="CenterScreen" Icon="/Images/OsLogo.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Settings panel -->
        <Grid Grid.Row="0" Height="80" Margin="10,10,10,0">
            <CheckBox Name="CheckBoxEnabled" HorizontalAlignment="Left" Margin="5,14,0,0" VerticalAlignment="Top"/>
            <Label Name="LabelEnabled" Content="Enable API" HorizontalAlignment="Left" Margin="28,15,0,0" VerticalAlignment="Top"/>

            <Label Name="LabelPort" Content="Port" HorizontalAlignment="Left" Margin="127,15,0,0" VerticalAlignment="Top"/>
            <TextBox Name="TextBoxPort" HorizontalAlignment="Left" Width="70" Height="22" Margin="170,14,0,0" VerticalAlignment="Top"/>

            <Label Name="LabelApiKey" Content="API Key" HorizontalAlignment="Left" Margin="264,15,0,0" VerticalAlignment="Top"/>
            <TextBox Name="TextBoxApiKey" HorizontalAlignment="Left" Width="250" Height="22" Margin="320,14,0,0" VerticalAlignment="Top"/>

            <CheckBox Name="CheckBoxFullLog" HorizontalAlignment="Left" Margin="5,48,0,0" VerticalAlignment="Top"/>
            <Label Name="LabelFullLog" Content="Full log (log every request and response)" HorizontalAlignment="Left" Margin="28,49,0,0" VerticalAlignment="Top"/>

            <Button Name="ButtonSave" Content="Save" Height="22" Margin="575,14,135,0" VerticalAlignment="Top"/>
            <Button Name="ButtonRestart" Content="Restart" Height="22" Margin="0,14,6,0" VerticalAlignment="Top" HorizontalAlignment="Right" Width="124"/>
        </Grid>

        <!-- Request log -->
        <WindowsFormsHost Name="HostRequests" Grid.Row="1" Margin="10"/>
    </Grid>
</Window>
