<Window x:Class="OsEngine.Entity.StrategyParametersUi"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Parameters" Height="450" MinHeight="300" MinWidth="550" Width="626" Topmost="False" Style="{StaticResource WindowStyleCanResize}" WindowStartupLocation="CenterOwner"  Icon="/Images/OsLogo.ico">
    <Grid>
        <TabControl Name="TabControlSettings" Margin="5,5,5,35">
        </TabControl>

        <Button Name="ButtonSaveSettings" Content="Save" Margin="5,0,0,5" VerticalAlignment="Bottom" HorizontalAlignment="Left" Width="125" Height="25" Click="ButtonSaveSettings_Click"/>
        <Button Name="ButtonLoadSettings" Content="Load" Margin="135,0,0,5" VerticalAlignment="Bottom" HorizontalAlignment="Left" Width="125" Height="25" Click="ButtonLoadSettings_Click"/>

        <Button Name="ButtonStrategyParameterPosts" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,5" Height="25" Width="25" Click="ButtonStrategyParameterPosts_Click" >
            <Grid>
                <Image Name="GreenCollectionStrategyParameter" Source="/Images/InstructionPosts/GreenPost.png"  Width="22" Height="17"/>
                <Image Name="WhiteCollectionStrategyParameter" Source="/Images/InstructionPosts/WhitePost.png" Width="22" Height="17" Opacity="0"/>
            </Grid>
        </Button>

        <Button Name="ButtonUpdate" Content="Update" Margin="0,0,135,5" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="125" Height="25" Click="ButtonUpdate_Click"/>
        <Button Name="ButtonAccept" Content="Accept" Margin="0,0,5,5" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="125" Height="25" Click="ButtonAccept_Click"/>
    </Grid>
</Window>

